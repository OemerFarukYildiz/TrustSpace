generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  industry    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets          Asset[]
  linkedAssets    LinkedAsset[]
  threatScenarios ThreatScenario[]
  riskThreats     RiskThreat[]
  risks       Risk[]
  controls    Control[]
  policies    Policy[]
  documentFiles   DocumentFile[]
  vendors     Vendor[]
  employees   Employee[]
  findings    Finding[]
  audits      Audit[]
  auditCalendar AuditCalendar[]
  sbomDocuments SbomDocument[]
  assetsV2        AssetV2[]
  risksV2         RiskV2[]

  @@map("organizations")
}

model Asset {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  type              String   // primary, secondary
  category          String   // information, process, hardware, software, personnel
  description       String?
  ownerId           String?
  department        String?
  
  // CIA-Triad (1-3 für Schutzbedarfsberechnung)
  confidentiality   Int      @default(0) // 0 = nicht berechnet, 1-3
  integrity         Int      @default(0) // 0 = nicht berechnet, 1-3
  availability      Int      @default(0) // 0 = nicht berechnet, 1-3
  ciaAverage        Float    @default(0) // Durchschnitt der 3 Werte
  
  // Workflow Status
  step1Completed    Boolean  @default(false) // CIA Berechnet
  step2Completed    Boolean  @default(false) // Assets verknüpft
  step3Completed    Boolean  @default(false) // Bedrohungen zugewiesen
  step4Completed    Boolean  @default(false) // Brutto/Netto Risiko
  step5Completed    Boolean  @default(false) // Maßnahmen gemappt
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner             Employee?    @relation(fields: [ownerId], references: [id])
  risks             Risk[]
  linkedAssets      LinkedAsset[] @relation("PrimaryAsset")
  linkedTo          LinkedAsset[] @relation("SecondaryAsset")
  riskThreats       RiskThreat[]
  sbomDocuments     SbomDocument[]

  @@map("assets")
}

model LinkedAsset {
  id              String   @id @default(cuid())
  organizationId  String
  primaryId       String   // Das Haupt-Asset
  secondaryId     String   // Das verknüpfte Asset
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryAsset    Asset    @relation("PrimaryAsset", fields: [primaryId], references: [id], onDelete: Cascade)
  secondaryAsset  Asset    @relation("SecondaryAsset", fields: [secondaryId], references: [id], onDelete: Cascade)

  @@unique([primaryId, secondaryId])
  @@map("linked_assets")
}

model ThreatScenario {
  id              String   @id @default(cuid())
  organizationId  String
  code            String   // B009, B006, etc.
  name            String
  description     String?
  category        String   // G: Gewalt, H: Höhere Gewalt, etc.
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  riskThreats     RiskThreat[]

  @@unique([organizationId, code])
  @@map("threat_scenarios")
}

model RiskThreat {
  id                String   @id @default(cuid())
  organizationId    String
  assetId           String
  threatId          String
  
  // Brutto-Risiko
  bruttoProbability Int      @default(1) // 1-5
  bruttoImpact      Int      @default(1) // 1-5
  bruttoScore       Int      @default(1)
  
  // Netto-Risiko (nach Maßnahmen)
  nettoProbability  Int      @default(1)
  nettoImpact       Int      @default(1)
  nettoScore        Int      @default(1)
  
  // Controls die diesem Threat gemappt sind
  mappedControls    String?  // JSON array of control IDs
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset             Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  threat            ThreatScenario   @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@unique([assetId, threatId])
  @@map("risk_threats")
}

model Risk {
  id                  String   @id @default(cuid())
  organizationId      String
  assetId             String?
  title               String
  description         String?
  
  // Brutto-Risiko (ohne Maßnahmen)
  bruttoProbability   Int      @default(1) // 1-5
  bruttoImpact        Int      @default(1) // 1-5
  bruttoScore         Int      @default(1)
  
  // Netto-Risiko (mit Maßnahmen)
  nettoProbability    Int      @default(1)
  nettoImpact         Int      @default(1)
  nettoScore          Int      @default(1)
  
  status              String   @default("open") // open, in_progress, mitigated, accepted
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset               Asset?       @relation(fields: [assetId], references: [id])
  controls            Control[]
  findings            Finding[]

  @@map("risks")
}

model Control {
  id                String   @id @default(cuid())
  organizationId    String
  code              String   // z.B. "A.5.1", "A.5.2"
  title             String
  description       String?
  justification     String?  // Begründung für SOA
  isApplicable      Boolean  @default(true)
  implementation    String?  // Implementierungsstatus
  responsibleId     String?

  // SOA Erweiterungen
  notes             String?
  implementationDate DateTime?
  reviewDate        DateTime?
  implementationPct Int      @default(0) // 0-100%

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responsible       Employee?    @relation(fields: [responsibleId], references: [id])
  risks             Risk[]
  findings          Finding[]
  policies          Policy[]
  evidenceFiles     ControlEvidence[]

  @@map("controls")
}

model ControlEvidence {
  id          String   @id @default(cuid())
  controlId   String
  fileName    String
  fileType    String
  fileData    String   // Base64 encoded
  mimeType    String?
  fileSize    Int      @default(0)
  description String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  control     Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("control_evidence")
}

model Policy {
  id              String   @id @default(cuid())
  organizationId  String
  title           String
  content         String?  // Rich text HTML content
  status          String   @default("draft") // draft, review, approved, expired
  version         Int      @default(1)
  fileUrl         String?
  fileType        String?  // pdf, docx
  controlId       String?
  
  // Document metadata
  category        String   @default("policies") // policies, procedural, work, external
  approverId      String?
  reviewDate      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  control         Control?     @relation(fields: [controlId], references: [id])

  @@map("policies")
}

model DocumentFile {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  type            String   // folder, docx, xlsx, pdf, txt, image, other
  parentId        String?  // null = root level
  size            Int      @default(0)
  
  // For editable content
  content         String?  // HTML content for Word docs
  sheetData       String?  // JSON array for Excel data
  
  // For binary files (images, PDFs)
  fileData        String?  // Base64 encoded file data
  mimeType        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent          DocumentFile? @relation("FolderStructure", fields: [parentId], references: [id])
  children        DocumentFile[] @relation("FolderStructure")

  @@map("document_files")
}

model Vendor {
  id                  String   @id @default(cuid())
  organizationId      String
  name                String
  category            String
  services            String?
  trustCenterUrl      String?
  certifications      String?  // JSON array
  dpoContact          String?
  gdprCompliant       Boolean?

  // Erweiterte Felder
  logoUrl             String?
  website             String?
  address             String?
  country             String?
  employeeCount       String?
  foundedYear         Int?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  dataProcessingAgreement Boolean @default(false)
  subProcessors       String?  // JSON array
  riskLevel           String?  // low, medium, high
  description         String?
  lastReviewDate      DateTime?
  nextReviewDate      DateTime?

  // Bewertung
  assessmentStatus    String   @default("none") // none, sent, evaluated, approved
  assessmentData      String?  // JSON mit Fragebogen-Antworten

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessments         VendorAssessment[]
  vendorDocuments     VendorDocument[]
  vendorComments      VendorComment[]

  @@map("vendors")
}

model VendorDocument {
  id          String   @id @default(cuid())
  vendorId    String
  fileName    String
  fileType    String
  fileData    String   // Base64
  mimeType    String?
  fileSize    Int      @default(0)
  category    String   @default("other") // contract, questionnaire, certificate, dpa, other
  description String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_documents")
}

model VendorComment {
  id        String   @id @default(cuid())
  vendorId  String
  authorId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_comments")
}

model VendorAssessment {
  id          String   @id @default(cuid())
  vendorId    String
  question    String
  answer      String   // yes, no, partial
  comment     String?
  createdAt   DateTime @default(now())

  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_assessments")
}

model Employee {
  id              String   @id @default(cuid())
  organizationId  String
  email           String
  firstName       String
  lastName        String
  role            String   // ISB, Admin, QM, etc.
  department      String?
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets          Asset[]
  controls        Control[]
  auditOwners     AuditOwner[]
  findings        Finding[]

  @@unique([organizationId, email])
  @@map("employees")
}

model Finding {
  id              String   @id @default(cuid())
  organizationId  String
  title           String
  description     String?
  type            String   // audit_finding, incident, improvement, task
  priority        String   @default("medium") // low, medium, high, critical
  status          String   @default("open") // open, in_progress, review, closed
  dueDate         DateTime?
  assigneeId      String?
  
  // Verknüpfungen
  riskId              String?
  controlId           String?
  auditId             String?
  vulnerabilityId     String?  // Link to VexVulnerability (CVE-Maßnahme)
  folder              String?  // Ordner/Version-Gruppe

  // Typ-spezifische Felder
  controlRef          String?  // für audit_finding: ISO-Kontrolle
  deviation           String?  // für audit_finding: Abweichung
  rootCause           String?  // für audit_finding: Ursache

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee        Employee?         @relation(fields: [assigneeId], references: [id])
  risk            Risk?             @relation(fields: [riskId], references: [id])
  control         Control?          @relation(fields: [controlId], references: [id])
  audit           Audit?            @relation(fields: [auditId], references: [id])
  vulnerability   VexVulnerability? @relation(fields: [vulnerabilityId], references: [id])
  comments        FindingComment[]
  attachments     FindingAttachment[]

  @@map("findings")
}

model FindingComment {
  id         String   @id @default(cuid())
  findingId  String
  authorName String   @default("System")
  content    String
  createdAt  DateTime @default(now())

  finding    Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  @@map("finding_comments")
}

model FindingAttachment {
  id        String   @id @default(cuid())
  findingId String
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  @@map("finding_attachments")
}

model FindingFolder {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   // vulnerability, audit_finding, improvement, incident, task
  createdAt      DateTime @default(now())

  @@unique([organizationId, type, name])
  @@map("finding_folders")
}

model Audit {
  id              String   @id @default(cuid())
  organizationId  String
  title           String
  type            String   // Internal Audit, External Audit, Certification, Review
  scope           String?
  plannedDate     DateTime
  actualDate      DateTime?
  description     String?
  status          String   @default("open") // open, close
  documents       String?  // JSON array of document metadata
  recurring       String?  // none, quarterly, semi-annual, annual
  seriesId        String?  // groups recurring audit instances together

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owners          AuditOwner[]
  findings        Finding[]
  auditCalendar   AuditCalendar[]

  @@map("audits")
}

model AuditOwner {
  id          String   @id @default(cuid())
  auditId     String
  employeeId  String
  createdAt   DateTime @default(now())

  audit       Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([auditId, employeeId])
  @@map("audit_owners")
}

model AuditCalendar {
  id          String   @id @default(cuid())
  organizationId String
  auditId     String?
  title       String
  date        DateTime
  type        String   // audit, finding_deadline, policy_review
  description String?
  
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audit       Audit?       @relation(fields: [auditId], references: [id])

  @@map("audit_calendar")
}

// SBOM Models
model SbomDocument {
  id            String   @id @default(cuid())
  organizationId String
  assetId       String
  format        String   // "cyclonedx" or "spdx"
  versionLabel  String   // e.g., "v1.0.0"
  isLatest      Boolean  @default(true)
  serialNumber  String?  // CycloneDX serial number
  rawJson       String   // Complete original SBOM JSON
  uploadedBy    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset         Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  components    SbomComponent[]

  @@map("sbom_documents")
}

model SbomComponent {
  id              String   @id @default(cuid())
  sbomDocumentId  String
  purl            String?  // Package URL
  cpe             String?  // Common Platform Enumeration
  name            String
  version         String?
  supplier        String?
  licenseSpdx     String?
  hashSha256      String?
  dependencyType  String   @default("unknown") // "direct", "transitive", "unknown"
  completeness    String   @default("incomplete") // "complete", "incomplete", "no-assertion"

  createdAt       DateTime @default(now())

  sbomDocument    SbomDocument           @relation(fields: [sbomDocumentId], references: [id], onDelete: Cascade)
  vulnerabilities VexVulnerability[]

  @@map("sbom_components")
}

model VexVulnerability {
  id              String   @id @default(cuid())
  componentId     String
  cveId           String   // e.g., "CVE-2023-1234"
  cvssScore       Float?
  severity        String   // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  vexStatus       String   @default("under_investigation") // "affected", "not_affected", "fixed", "under_investigation"
  remediation     String?
  lastCheckedAt   DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  component       SbomComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  findings        Finding[]

  @@unique([componentId, cveId])
  @@map("vex_vulnerabilities")
}

// ============ V2 MODELS ============

model AssetV2 {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  description       String?
  category          String   // information, application, infrastructure, personnel, physical
  subCategory       String?
  ownerId           String?
  department        String?

  // CIA-Triad (1-10 Skala)
  confidentiality   Int      @default(0)
  integrity         Int      @default(0)
  availability      Int      @default(0)
  ciaScore          Float    @default(0) // Durchschnitt

  // Monetaere Bewertung
  replacementCost   Float?   // EUR
  revenueImpact     Float?   // EUR pro Tag Ausfall

  dataClassification String  @default("internal") // public, internal, confidential, restricted
  status            String   @default("active") // active, decommissioned, planned
  location          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  risksV2           RiskV2[]

  @@map("assets_v2")
}

model RiskV2 {
  id                String   @id @default(cuid())
  organizationId    String
  assetId           String?
  title             String
  description       String?
  riskCategory      String?  // operational, strategic, compliance, financial, technical
  threatSource      String?  // internal, external, environmental
  vulnerability     String?

  // Brutto-Risiko (1-10)
  bruttoProbability Int      @default(1)
  bruttoImpact      Int      @default(1)
  bruttoScore       Int      @default(1) // prob * impact

  // Netto-Risiko (1-10)
  nettoProbability  Int      @default(1)
  nettoImpact       Int      @default(1)
  nettoScore        Int      @default(1)

  // FAIR / Quantitativ
  singleLossExpectancy Float? // SLE in EUR
  annualRateOccurrence Float? // ARO (z.B. 0.1 = alle 10 Jahre)
  annualLossExpectancy Float? // ALE = SLE * ARO
  nettoSLE             Float?
  nettoARO             Float?
  nettoALE             Float?

  // Behandlung
  riskTreatment     String?  // mitigate, accept, transfer, avoid
  riskOwner         String?
  treatmentPlan     String?
  treatmentDeadline DateTime?

  status            String   @default("identified") // identified, assessed, treated, monitored, closed
  mappedControls    String?  // JSON array of control IDs

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset             AssetV2?     @relation(fields: [assetId], references: [id])

  @@map("risks_v2")
}
