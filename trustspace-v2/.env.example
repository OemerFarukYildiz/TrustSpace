# Database
DATABASE_URL="file:./dev.db"

# Auth (NextAuth)
AUTH_SECRET="your-secret-key-here"
AUTH_URL="http://localhost:3000"

# LLM Configuration
LLM_PROVIDER=ollama
# Options: ollama, claude, openai

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Claude (production)
ANTHROPIC_API_KEY=

# OpenAI (alternative)
OPENAI_API_KEY=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
